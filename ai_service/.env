# ===================================
# EduPath AI Service Configuration
# ===================================

# Environment
ENVIRONMENT=development
DEBUG=true

# Server Configuration
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000

BACKEND_URL=http://localhost:4000

# ===================================
# HuggingFace Configuration
# ===================================
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=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

# LLM Model Configuration
LLM_MODEL=HuggingFaceH4/zephyr-7b-beta
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ===================================
# Model Cache & Performance
# ===================================
MODEL_CACHE_DIR=./models_cache
MAX_RETRIES=3
REQUEST_TIMEOUT=120

# ===================================
# Logging
# ===================================
LOG_LEVEL=INFO
LOG_FILE=ai_service.log

# ===================================
# MongoDB Configuration
# ===================================
MONGODB_URI=mongodb+srv://patelmihir:edupath2026@edupathdb.hvermlv.mongodb.net/?appName=EduPathDB
DATABASE_NAME=edupath

# ===================================
# Compatibility Variables
# ===================================
HUGGINGFACE_API_KEY=${HUGGINGFACE_API_TOKEN}

# ===================================
# Additional Performance Settings
# ===================================
MAX_WORKERS=4
USE_MODEL_CACHE=true
CACHE_DIR=./model_cache

# ===================================
# Assessment Thresholds
# ===================================
BEGINNER_THRESHOLD=50.0
INTERMEDIATE_THRESHOLD=70.0
ADVANCED_THRESHOLD=85.0

# ===================================
# Score Weights
# ===================================
ACCURACY_WEIGHT=0.6
DIFFICULTY_WEIGHT=0.4